# Copy this file to .env and fill in the real values.
# NEVER commit .env to source control.

# Docker Hub 用户名（docker-compose.yml 用来定位镜像）
DOCKERHUB_USERNAME=your_dockerhub_username

# PostgreSQL connection string
DB_CONNECTION_STRING=Host=152.136.11.140;Port=6286;Database=musespace_dev;Username=msadmin;Password=YOUR_PASSWORD_HERE;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=20;

# OpenRouter LLM（主渠道）
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-REPLACE_ME
LLM_MODEL_NAME=z-ai/glm-4.5-air:free

# DeepSeek LLM（备用渠道，可切换）
DEEPSEEK_API_KEY=sk-REPLACE_ME

# SiliconFlow 向量化（Embedding）
EMBEDDING_API_KEY=sk-REPLACE_ME
