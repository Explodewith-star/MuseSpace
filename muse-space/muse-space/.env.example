# Copy this file to .env and fill in the real values.
# NEVER commit .env to source control.

# GitHub 用户名（小写），用于定位 ghcr.io 上的镜像
# 例：Explodewith-star -> explodewith-star
GITHUB_USERNAME=your_github_username_lowercase

# PostgreSQL connection string
DB_CONNECTION_STRING=Host=152.136.11.140;Port=6286;Database=musespace_dev;Username=msadmin;Password=YOUR_PASSWORD_HERE;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=20;

# OpenRouter LLM（主渠道）
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-REPLACE_ME
LLM_MODEL_NAME=z-ai/glm-4.5-air:free

# DeepSeek LLM（备用渠道，可切换）
DEEPSEEK_API_KEY=sk-REPLACE_ME

# SiliconFlow 向量化（Embedding）
EMBEDDING_API_KEY=sk-REPLACE_ME

# ── 认证与管理员（Phase 2 用户模块）────────────────────────────────────────
# JWT 签名密钥：必须 ≥32 字符随机字符串（可用 `openssl rand -base64 48` 生成）
# 未配置或少于 32 字符时后端会 fail-fast 拒绝启动
AUTH_JWT_SECRET=REPLACE_WITH_RANDOM_32PLUS_CHAR_SECRET
AUTH_USER_TOKEN_EXPIRY_DAYS=7
AUTH_ADMIN_TOKEN_EXPIRY_HOURS=24

# 管理员账号：手机号 + 密码的 BCrypt 哈希
# 首次部署时留空，启动后用任意密码调一次 /api/auth/admin-login，
# 后端会在日志中打印哈希；复制回填此处后重启即可
ADMIN_PHONE_NUMBER=
ADMIN_PASSWORD_HASH=
